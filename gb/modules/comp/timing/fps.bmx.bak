
Type t_gb_timing_fps
  Field ticks   :t_long
  Field value   :t_long
  Field time    :t_long
EndType

Function new_gb_timing_fps:t_gb_timing_fps ()
  Local r:t_gb_timing_fps = New t_gb_timing_fps
  r.ticks   = new_int(0)
  r.value   = new_int(0)
  r.time    = new_long(0)
  Return r
EndFunction